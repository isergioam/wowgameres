---
import BaseLayout from "../layouts/BaseLayout.astro";
import NewsCard from "../components/NewsCard.astro";
import newsData from "../content/news/latest.json";
import { Image } from "astro:assets";
import heroImage from "../assets/images/Cabecera_WOWGamerES.webp";

const expansions = [
  { id: "vanilla", name: "Vanilla" },
  { id: "tbc", name: "Terrallende" },
  { id: "wotlk", name: "Rasganorte" },
  { id: "cata", name: "Cataclismo" },
  { id: "mop", name: "Pandaria" },
  { id: "wod", name: "Draenor" },
  { id: "legion", name: "Legión" },
  { id: "bfa", name: "Battle for Azeroth" },
  { id: "sl", name: "Shadowlands" },
  { id: "df", name: "Dragonflight" },
  { id: "tww", name: "The War Within" },
  { id: "midnight", name: "Midnight" },
];

const latestNews = newsData.slice(0, 3);
const title = "Guías de Profesiones WoW & Noticias de Azeroth | WOWGamerES";
const description =
  "Las mejores guías de nivelación de profesiones para World of Warcraft y las últimas noticias de Azeroth resumidas por IA. Optimiza tu juego con WOWGamerES.";
---

<BaseLayout title={title} description={description}>
  <section class="hero-section reveal">
    <div class="hero-background">
      <Image 
        src={heroImage} 
        alt="Fondo de cabecera WOWGamerES" 
        width={1920} 
        height={1080} 
        format="avif"
        quality="mid"
        loading="eager"
        fetchpriority="high"
        class="hero-img-asset"
      />
    </div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1 id="profesiones" data-i18n="title_professions">
        Guías de Profesiones World of Warcraft: Paso a Paso
      </h1>
      <p class="hero-description">
        Bienvenido a <strong>WOWGamerES</strong>, el recurso definitivo para dominar las <strong>profesiones de WoW</strong>. Nuestra misión es ayudarte a alcanzar el nivel máximo de forma rápida, eficiente y optimizando cada moneda de oro en todas las expansiones, desde Vanilla hasta Midnight.
      </p>
      <div class="hero-stats">
        <div class="stat-item">
          <span class="stat-value">12</span>
          <span class="stat-label">Expansiones</span>
        </div>
        <div class="stat-item">
          <span class="stat-value">100%</span>
          <span class="stat-label">Actualizado</span>
        </div>
        <div class="stat-item">
          <span class="stat-value">Free</span>
          <span class="stat-label">Siempre gratis</span>
        </div>
      </div>
    </div>
  </section>

  <main class="content">
    <!-- Expansiones -->
    <section id="expansiones" class="section">
      <div style="margin-bottom: 25px; text-align: center;">
        <h2 data-i18n="title_explore">
          Comienza tu aventura: Elige una Expansión
        </h2>
        <p style="opacity: 0.8; margin-top: 10px;">
          Selecciona la era temporal en la que deseas mejorar tus habilidades de
          artesanía o recolección.
        </p>
      </div>

      <div class="expansiones">
        {
          expansions.map((exp) => (
            <a href={`/guias/${exp.id}/`} class="card-expansion-link reveal">
              <div class="card-expansion">{exp.name}</div>
            </a>
          ))
        }
      </div>
    </section>

    <!-- Últimas Noticias -->
    {
      latestNews.length > 0 && (
        <section
          class="section news-preview-section reveal"
          style="margin-top: 50px;"
        >
          <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 25px;">
            <h2 style="border: none; padding: 0; margin: 0;">
              Últimas Noticias de Azeroth
            </h2>
            <a
              href="/noticias/"
              style="color: var(--primary-purple); font-weight: 600; font-size: 0.9rem;"
            >
              Ver todas &rarr;
            </a>
          </div>
          <div class="news-grid">
            {latestNews.map((news) => (
              <NewsCard
                title={news.title}
                description={news.summary || news.description}
                slug={news.slug}
                image={news.image}
                date={news.date}
                category={news.category}
              />
            ))}
          </div>
        </section>
      )
    }

    <!-- Sección Cinemática Informativa (Minimalista) -->
    <section class="cinematic-info-section reveal">
      <div class="cinematic-bg">
        <Image src={heroImage} alt="Cinematic Background" class="bg-img" />
        <div class="cinematic-overlay"></div>
      </div>
      <div class="cinematic-container">
        <header class="cinematic-header">
          <h2>¿Por qué utilizar nuestras guías?</h2>
          <div class="accent-line"></div>
        </header>
        <div class="cinematic-grid">
          <div class="cinematic-item">
            <h3>Rutas Optimizadas</h3>
            <p>Estructuramos cada tramo seleccionando las recetas más eficientes y económicas de la casa de subastas.</p>
          </div>
          <div class="cinematic-item">
            <h3>Progreso Real</h3>
            <p>Herramientas interactivas integradas para tachar materiales y guardar tu avance automáticamente.</p>
          </div>
          <div class="cinematic-item">
            <h3>Siempre Al Día</h3>
            <p>Revisamos cada parche y expansión para asegurar que nuestras rutas nunca queden obsoletas.</p>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .hero-section {
    position: relative;
    height: 60vh;
    min-height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: white;
    overflow: hidden;
    margin-top: calc(-1 * var(--header-height-desktop));
    padding-top: var(--header-height-desktop);
  }

  .hero-background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -2;
    overflow: hidden;
  }

  .hero-img-asset {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.6);
    animation: slowZoom 20s infinite alternate ease-in-out;
  }

  @keyframes slowZoom {
    from {
      transform: scale(1);
    }
    to {
      transform: scale(1.15);
    }
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.5) 0%,
      rgba(0, 0, 0, 0.2) 40%,
      rgba(10, 5, 25, 0.7) 70%,
      #0a0519 100%
    );
    z-index: -1;
  }

  .dark-mode .hero-overlay {
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.7) 0%,
      rgba(0, 0, 0, 0.4) 50%,
      #000000 100%
    );
  }

  .hero-content {
    max-width: 900px;
    padding: 0 20px;
    z-index: 1;
    animation: fadeInUp 1s ease-out;
  }

  .hero-section h1 {
    font-size: 3.5rem;
    font-weight: 900;
    color: white;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.8);
    margin-bottom: 20px;
    border: none;
    padding: 0;
    line-height: 1.1;
  }

  .hero-description {
    font-size: 1.25rem;
    line-height: 1.6;
    margin-bottom: 40px;
    color: rgba(255, 255, 255, 0.9);
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 40px;
    margin-top: 30px;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
  }

  .stat-value {
    font-size: 2.2rem;
    font-weight: 800;
    color: #bb9fff; /* Usamos el púrpura claro siempre aquí para contraste */
    text-shadow: 0 0 15px rgba(187, 159, 255, 0.3);
  }

  .stat-label {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: rgba(255, 255, 255, 0.7);
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .news-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 25px;
    margin-bottom: 40px;
  }

  /* --- CINEMATIC INFO SECTION --- */
  .cinematic-info-section {
    position: relative;
    width: 100vw;
    margin-left: 50%;
    transform: translateX(-50%);
    padding: 80px 0;
    color: white;
    overflow: hidden;
    margin-top: 40px;
    margin-bottom: 40px;
  }

  .cinematic-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
  }

  .cinematic-bg .bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.45) saturate(0.7);
  }

  .cinematic-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, 
      #000 0%, 
      transparent 20%, 
      transparent 80%, 
      #000 100%
    );
  }

  .cinematic-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
    position: relative;
    z-index: 1;
  }

  .cinematic-header {
    text-align: center;
    margin-bottom: 50px;
  }

  .cinematic-header h2 {
    font-size: 3rem;
    font-weight: 900;
    letter-spacing: -1.5px;
    margin-bottom: 25px;
    border: none;
    padding: 0;
    text-transform: uppercase;
  }

  .accent-line {
    width: 80px;
    height: 4px;
    background: #bb9fff;
    margin: 0 auto;
    box-shadow: 0 0 15px rgba(187, 159, 255, 0.5);
  }

  .cinematic-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
  }

  .cinematic-item {
    text-align: center;
  }

  .cinematic-item h3 {
    font-size: 1.2rem;
    font-weight: 800;
    color: #bb9fff;
    margin-bottom: 20px;
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .cinematic-item p {
    font-size: 1.05rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.8);
    font-weight: 400;
  }

  /* --- LIGHT MODE ADAPTATION --- */
  html:not(.dark-mode) .cinematic-info-section {
    color: #1a1a2e;
    background-color: #f9f7ff;
  }

  html:not(.dark-mode) .cinematic-bg .bg-img {
    filter: brightness(1.7) saturate(0.4) opacity(0.2);
  }

  html:not(.dark-mode) .cinematic-overlay {
    background: linear-gradient(to bottom, 
      #ffffff 0%, 
      transparent 20%, 
      transparent 80%, 
      #ffffff 100%
    );
  }

  html:not(.dark-mode) .cinematic-header h2 {
    color: #1a1a2e;
  }

  html:not(.dark-mode) .accent-line {
    background: #6a0dad;
    box-shadow: 0 4px 10px rgba(106, 13, 173, 0.2);
  }

  html:not(.dark-mode) .cinematic-item h3 {
    color: #6a0dad;
  }

  html:not(.dark-mode) .cinematic-item p {
    color: #444;
  }

  @media (max-width: 1024px) and (min-width: 769px) {
    .hero-section {
      height: auto;
      padding: 180px 40px 100px;
      margin-top: calc(-1 * var(--header-height-tablet));
    }
    .hero-section h1 {
      font-size: 2.8rem;
    }
  }

  @media (max-width: 768px) {
    .hero-section {
      height: auto;
      padding: 180px 20px 100px;
      margin-top: calc(-1 * var(--header-height-mobile));
    }

    .hero-section h1 {
      font-size: 2.2rem;
    }

    .hero-stats {
      gap: 20px;
      flex-wrap: wrap;
    }

    .news-grid {
      grid-template-columns: 1fr;
    }

    .cinematic-info-section {
      padding: 60px 0;
    }

    .cinematic-header h2 {
      font-size: 1.8rem;
    }

    .cinematic-grid {
      grid-template-columns: 1fr;
      gap: 50px;
    }

    .cinematic-container {
      padding: 0 20px;
    }
  }
</style>
