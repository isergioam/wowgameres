---
import BaseLayout from "../layouts/BaseLayout.astro";
import NewsCard from "../components/NewsCard.astro";
import newsData from "../content/news/latest.json";

const expansions = [
  { id: "vanilla", name: "Vanilla" },
  { id: "tbc", name: "Terrallende" },
  { id: "wotlk", name: "Rasganorte" },
  { id: "cata", name: "Cataclismo" },
  { id: "mop", name: "Pandaria" },
  { id: "wod", name: "Draenor" },
  { id: "legion", name: "Legión" },
  { id: "bfa", name: "Battle for Azeroth" },
  { id: "sl", name: "Shadowlands" },
  { id: "df", name: "Dragonflight" },
  { id: "tww", name: "The War Within" },
  { id: "midnight", name: "Midnight" },
];

const latestNews = newsData.slice(0, 3);
const title = "Guías de Profesiones WoW & Noticias de Azeroth | WOWGamerES";
const description =
  "Las mejores guías de nivelación de profesiones para World of Warcraft y las últimas noticias de Azeroth resumidas por IA. Optimiza tu juego con WOWGamerES.";
---

<BaseLayout title={title} description={description} preloadImage="/images/Cabecera_WOWGamerES.webp">
  <section class="hero-section reveal">
    <div class="hero-background"></div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1 id="profesiones" data-i18n="title_professions">
        Guías paso a paso para World of Warcraft
      </h1>
      <p class="hero-description">
        Bienvenido a <strong>WOWGamerES</strong>, el recurso definitivo creado
        por jugadores y para jugadores. Nuestro objetivo es ayudarte a subir las
        profesiones de tus personajes de forma rápida, eficiente y gastando la
        menor cantidad de oro posible.
      </p>
      <div class="hero-stats">
        <div class="stat-item">
          <span class="stat-value">12</span>
          <span class="stat-label">Expansiones</span>
        </div>
        <div class="stat-item">
          <span class="stat-value">100%</span>
          <span class="stat-label">Actualizado</span>
        </div>
        <div class="stat-item">
          <span class="stat-value">Free</span>
          <span class="stat-label">Siempre gratis</span>
        </div>
      </div>
    </div>
  </section>

  <main class="content">
    <!-- Expansiones -->
    <section id="expansiones" class="section">
      <div style="margin-bottom: 25px; text-align: center;">
        <h2 data-i18n="title_explore">
          Comienza tu aventura: Elige una Expansión
        </h2>
        <p style="opacity: 0.8; margin-top: 10px;">
          Selecciona la era temporal en la que deseas mejorar tus habilidades de
          artesanía o recolección.
        </p>
      </div>

      <div class="expansiones">
        {
          expansions.map((exp) => (
            <a href={`/guias/${exp.id}/`} class="card-expansion-link reveal">
              <div class="card-expansion">{exp.name}</div>
            </a>
          ))
        }
      </div>
    </section>

    <!-- Últimas Noticias -->
    {
      latestNews.length > 0 && (
        <section
          class="section news-preview-section reveal"
          style="margin-top: 50px;"
        >
          <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 25px;">
            <h2 style="border: none; padding: 0; margin: 0;">
              Últimas Noticias de Azeroth
            </h2>
            <a
              href="/noticias/"
              style="color: var(--primary-purple); font-weight: 600; font-size: 0.9rem;"
            >
              Ver todas &rarr;
            </a>
          </div>
          <div class="news-grid">
            {latestNews.map((news) => (
              <NewsCard
                title={news.title}
                description={news.summary || news.description}
                slug={news.slug}
                image={news.image}
                date={news.date}
                category={news.category}
              />
            ))}
          </div>
        </section>
      )
    }

    <!-- Nueva sección para añadir densidad de texto y valor (E-E-A-T) -->
    <section
      class="section faq-section reveal"
      style="margin-top: 50px; text-align: left;"
    >
      <h2>¿Por qué utilizar nuestras guías?</h2>
      <div style="margin-top: 20px; display: grid; gap: 20px;">
        <article>
          <h3 style="color: #bb9fff; margin-bottom: 5px;">
            Rutas Optimizadas paso a paso
          </h3>
          <p>
            Nos encargamos de estructurar cada tramo de nivel (por ejemplo, del
            1 al 75 o del 1 al 300) seleccionando siempre las recetas que
            consumen materiales más comunes y baratos en la casa de subastas.
            Rehuimos sistemáticamente de componentes raros salvo que sean
            estrictamente necesarios.
          </p>
        </article>
        <article>
          <h3 style="color: #bb9fff; margin-bottom: 5px;">
            Rastreador de Progreso Integrado
          </h3>
          <p>
            Nuestras guías no son solo texto estático. Cada página de profesión
            incluye una herramienta interactiva donde puedes tachar los
            materiales que vas consiguiendo y llevar la cuenta de en qué nivel
            te has quedado, guardándose automáticamente en tu navegador.
          </p>
        </article>
        <article>
          <h3 style="color: #bb9fff; margin-bottom: 5px;">
            Actualizaciones Constantes
          </h3>
          <p>
            El universo de Azeroth cambia constantemente. Parche tras parche,
            revisamos las dinámicas de farmeo y ajuste de recetas que Blizzard
            introduce, asegurándonos de que nunca sigas una ruta que haya
            quedado obsoleta.
          </p>
        </article>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .hero-section {
    position: relative;
    height: 60vh;
    min-height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: white;
    overflow: hidden;
    margin-top: calc(-1 * var(--header-height-desktop));
    padding-top: var(--header-height-desktop);
  }

  .hero-background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: url("/images/Cabecera_WOWGamerES.webp");
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    z-index: -2;
    filter: brightness(0.6); /* Oscurecemos la imagen para más dramatismo */
    animation: slowZoom 20s infinite alternate ease-in-out;
  }

  @keyframes slowZoom {
    from {
      transform: scale(1);
    }
    to {
      transform: scale(1.15);
    }
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.5) 0%,
      rgba(0, 0, 0, 0.2) 40%,
      rgba(10, 5, 25, 0.7) 70%,
      #0a0519 100%
    );
    z-index: -1;
  }

  .dark-mode .hero-overlay {
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.7) 0%,
      rgba(0, 0, 0, 0.4) 50%,
      #000000 100%
    );
  }

  .hero-content {
    max-width: 900px;
    padding: 0 20px;
    z-index: 1;
    animation: fadeInUp 1s ease-out;
  }

  .hero-section h1 {
    font-size: 3.5rem;
    font-weight: 900;
    color: white;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.8);
    margin-bottom: 20px;
    border: none;
    padding: 0;
    line-height: 1.1;
  }

  .hero-description {
    font-size: 1.25rem;
    line-height: 1.6;
    margin-bottom: 40px;
    color: rgba(255, 255, 255, 0.9);
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 40px;
    margin-top: 30px;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
  }

  .stat-value {
    font-size: 2.2rem;
    font-weight: 800;
    color: #bb9fff; /* Usamos el púrpura claro siempre aquí para contraste */
    text-shadow: 0 0 15px rgba(187, 159, 255, 0.3);
  }

  .stat-label {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: rgba(255, 255, 255, 0.7);
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .news-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 25px;
    margin-bottom: 40px;
  }

  @media (max-width: 768px) {
    .hero-section {
      height: auto;
      padding: 180px 20px 100px;
      margin-top: calc(-1 * var(--header-height-mobile));
    }

    .hero-section h1 {
      font-size: 2.2rem;
    }

    .hero-stats {
      gap: 20px;
      flex-wrap: wrap;
    }

    .news-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
