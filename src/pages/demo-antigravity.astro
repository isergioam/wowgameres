---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Showcase: El Poder de la IA en WOWGamerES";
const description = "Una demostración interactiva de lo que Antigravity puede hacer para transformar este proyecto.";
---

<BaseLayout title={title} description={description}>
  <div class="showcase-wrapper">
    <!-- Hero Section with Typewriter -->
    <section class="showcase-hero">
      <div class="hero-bg-glow"></div>
      <div class="container">
        <div class="hero-header">
          <span class="badge">Demo Interactiva</span>
          <h1>Hola, soy <span>Antigravity</span></h1>
          <div class="typewriter-container">
            <p id="typewriter-text"></p>
            <span class="cursor">|</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Capabilities Grid -->
    <section class="capabilities-section">
      <div class="container">
        <h2 class="section-title">¿Qué puedo hacer por este proyecto?</h2>
        <div class="capabilities-grid">
          <div class="capability-card">
            <div class="card-icon">🚀</div>
            <h3>Desarrollo Ultrarrápido</h3>
            <p>Puedo crear páginas completas, componentes y funcionalidades complejas en segundos, no horas.</p>
          </div>
          <div class="capability-card">
            <div class="card-icon">🔍</div>
            <h3>SEO & Rendimiento</h3>
            <p>Optimizo cada línea de código para que Google adore la página y cargue de forma instantánea.</p>
          </div>
          <div class="capability-card">
            <div class="card-icon">✍️</div>
            <h3>Generación de Contenido</h3>
            <p>Desde guías de profesiones hasta las últimas noticias de Azeroth, todo redactado y optimizado.</p>
          </div>
          <div class="capability-card">
            <div class="card-icon">🛠️</div>
            <h3>Resolución de Problemas</h3>
            <p>Identifico errores, corrijo bugs y refactorizo código para mantener el proyecto limpio y profesional.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Terminal Simulation -->
    <section class="terminal-section">
      <div class="container">
        <div class="terminal-window">
          <div class="terminal-header">
            <div class="dots">
              <span class="dot red"></span>
              <span class="dot yellow"></span>
              <span class="dot green"></span>
            </div>
            <div class="terminal-title">antigravity@wowgameres: ~</div>
          </div>
          <div class="terminal-body" id="terminal-content">
            <div class="line"><span class="prompt">$</span> analyze_project_structure</div>
            <div class="line">... Analizando 142 archivos en /src</div>
            <div class="line">... Detectando oportunidades de SEO</div>
            <div class="line">... Optimizando imágenes para dispositivos móviles</div>
            <div class="line"><span class="prompt">$</span> build_premium_ui --theme="wow-epic"</div>
            <div class="line">[OK] Interfaz generada con éxito.</div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-box">
          <h2>Esto es solo el comienzo</h2>
          <p>Estoy aquí para ayudar a convertir este sitio en la referencia #1 para todos los jugadores de WoW.</p>
          <a href="/" class="btn-primary">Volver al Inicio</a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  // Typewriter effect
  const text = "Soy tu asistente de IA personal. Ayudo a tu hermano a construir el mejor sitio web de guías de WoW del mundo. Programo, diseño y optimizo en tiempo real.";
  const element = document.getElementById('typewriter-text');
  let i = 0;

  function typeWriter() {
    if (i < text.length) {
      if (element) element.innerHTML += text.charAt(i);
      i++;
      setTimeout(typeWriter, 40);
    }
  }

  // Start typewriter when section is in view
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        typeWriter();
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.5 });

  const heroSection = document.querySelector('.showcase-hero');
  if (heroSection) observer.observe(heroSection);

  // Simple terminal animation
  const terminalLines = [
    { text: "generating_new_feature --target=guides", color: "white" },
    { text: "fetching data from Blizzard API...", color: "cyan" },
    { text: "SEO Score: 100/100", color: "green" },
    { text: "Deploying updates to production...", color: "white" },
    { text: "Done. Everything is working perfectly.", color: "green" }
  ];

  const terminalContent = document.getElementById('terminal-content');
  let lineIndex = 0;

  function addTerminalLine() {
    if (lineIndex < terminalLines.length && terminalContent) {
      const line = document.createElement('div');
      line.className = 'line';
      line.innerHTML = `<span class="prompt">$</span> <span style="color: ${terminalLines[lineIndex].color}">${terminalLines[lineIndex].text}</span>`;
      terminalContent.appendChild(line);
      lineIndex++;
      setTimeout(addTerminalLine, 1500);
    }
  }

  // Start terminal animation after a delay
  setTimeout(addTerminalLine, 2000);
</script>

<style>
  :root {
    --accent-color: #bb9fff;
    --accent-dark: #6a0dad;
    --text-glow: rgba(187, 159, 255, 0.4);
    --glass-bg: rgba(255, 255, 255, 0.03);
    --glass-border: rgba(255, 255, 255, 0.1);
  }

  .showcase-wrapper {
    background-color: #0a0519;
    color: white;
    min-height: 100vh;
    font-family: 'Inter', system-ui, sans-serif;
    overflow-x: hidden;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* Hero Section */
  .showcase-hero {
    position: relative;
    padding: 120px 0 80px;
    text-align: center;
    overflow: hidden;
  }

  .hero-bg-glow {
    position: absolute;
    top: -20%;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, var(--accent-dark) 0%, transparent 70%);
    filter: blur(80px);
    opacity: 0.3;
    z-index: 0;
  }

  .hero-header {
    position: relative;
    z-index: 1;
  }

  .badge {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    padding: 6px 16px;
    border-radius: 20px;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--accent-color);
    margin-bottom: 24px;
    display: inline-block;
  }

  h1 {
    font-size: 4rem;
    font-weight: 900;
    margin-bottom: 24px;
    line-height: 1.1;
  }

  h1 span {
    background: linear-gradient(90deg, #fff, var(--accent-color));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    text-shadow: 0 0 30px var(--text-glow);
  }

  .typewriter-container {
    font-size: 1.5rem;
    color: rgba(255, 255, 255, 0.8);
    max-width: 700px;
    margin: 0 auto;
    min-height: 80px;
    line-height: 1.6;
  }

  .cursor {
    display: inline-block;
    width: 3px;
    background-color: var(--accent-color);
    margin-left: 4px;
    animation: blink 1s infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  /* Capabilities */
  .capabilities-section {
    padding: 100px 0;
  }

  .section-title {
    text-align: center;
    font-size: 2.5rem;
    margin-bottom: 60px;
  }

  .capabilities-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 30px;
  }

  .capability-card {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    padding: 40px;
    border-radius: 24px;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    backdrop-filter: blur(10px);
  }

  .capability-card:hover {
    transform: translateY(-10px);
    border-color: var(--accent-color);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4), 0 0 20px rgba(187, 159, 255, 0.1);
  }

  .card-icon {
    font-size: 3rem;
    margin-bottom: 20px;
  }

  .capability-card h3 {
    font-size: 1.5rem;
    margin-bottom: 16px;
    color: white;
  }

  .capability-card p {
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.6;
  }

  /* Terminal */
  .terminal-section {
    padding: 100px 0;
  }

  .terminal-window {
    background: #000;
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.6);
    max-width: 800px;
    margin: 0 auto;
  }

  .terminal-header {
    background: #1a1a1a;
    padding: 12px 20px;
    display: flex;
    align-items: center;
    border-bottom: 1px solid #333;
  }

  .dots {
    display: flex;
    gap: 8px;
    margin-right: 20px;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .red { background: #ff5f56; }
  .yellow { background: #ffbd2e; }
  .green { background: #27c93f; }

  .terminal-title {
    font-family: monospace;
    font-size: 0.8rem;
    color: #888;
  }

  .terminal-body {
    padding: 24px;
    font-family: 'Fira Code', 'Courier New', monospace;
    font-size: 0.95rem;
    line-height: 1.8;
    color: #eee;
    min-height: 300px;
  }

  .line {
    margin-bottom: 4px;
    animation: fadeIn 0.3s ease-out;
  }

  .prompt {
    color: var(--accent-color);
    margin-right: 8px;
    font-weight: bold;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateX(-10px); }
    to { opacity: 1; transform: translateX(0); }
  }

  /* CTA */
  .cta-section {
    padding: 120px 0;
  }

  .cta-box {
    background: linear-gradient(135deg, var(--accent-dark) 0%, #1a0b3d 100%);
    padding: 80px 40px;
    border-radius: 40px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .cta-box h2 {
    font-size: 3rem;
    margin-bottom: 20px;
  }

  .cta-box p {
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 40px;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .btn-primary {
    display: inline-block;
    background: white;
    color: #000;
    padding: 16px 40px;
    border-radius: 30px;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .btn-primary:hover {
    transform: scale(1.05);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
  }

  /* Responsive */
  @media (max-width: 768px) {
    h1 { font-size: 2.8rem; }
    .typewriter-container { font-size: 1.1rem; }
    .section-title { font-size: 2rem; }
    .cta-box h2 { font-size: 2.2rem; }
  }
</style>
