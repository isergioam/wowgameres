---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsCard from '../../components/NewsCard.astro';
import { getEntry } from 'astro:content';

export async function getStaticPaths({ paginate }) {
  const newsEntry = await getEntry('news', 'latest');
  const allNews = newsEntry ? newsEntry.data : [];
  
  // Excluimos la primera noticia (Hero) de la paginación para que no se repita
  const remainingNews = allNews.slice(1);
  const featuredNews = allNews[0];

  const pages = paginate(remainingNews, { 
    pageSize: 9,
    props: { featuredNews } 
  });

  // Solo queremos generar las páginas de la 2 en adelante
  return pages.filter(p => p.params.page !== "1");
}

const { page, featuredNews } = Astro.props;
const { data: newsItems } = page;

// Orden fijo de categorías (igual que en noticias.astro)
const CATEGORY_ORDER = ['Todas', 'Novedades', 'Qué hacer', 'Retail', 'Classic', 'Housing', 'Puesto comercial', 'Comunidad'];
const existingCategories = new Set(newsItems.map(item => item.category));
const categories = CATEGORY_ORDER.filter(cat => cat === 'Todas' || existingCategories.has(cat));

const title = `Noticias WoW - Página ${page.currentPage} | WOWGamerES`;
const description = "Explora el historial completo de noticias de World of Warcraft, Midnight y Classic.";
---

<BaseLayout title={title} description={description}>
  
  {page.currentPage === 1 && featuredNews && (
    <section class="hero-cinematic">
      <div class="hero-bg">
        <img src={featuredNews.image} alt={featuredNews.title} />
        <div class="hero-overlay"></div>
      </div>
      <div class="hero-container content">
        <div class="hero-content">
          <div class="hero-meta">
            <span class="category-chip">{featuredNews.category}</span>
            <time>{new Date(featuredNews.date).toLocaleDateString('es-ES', { day: 'numeric', month: 'long' })}</time>
          </div>
          <h1>{featuredNews.title}</h1>
          <p>{featuredNews.description}</p>
          <a href={`/noticias/${featuredNews.slug}`} class="cta-banner">
            LEER ARTÍCULO 
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </a>
        </div>
      </div>
    </section>
  )}

  <main class="content main-news-section">
    <!-- Toolbar -->
    <div class="toolbar-sticky">
      <section class="news-toolbar-glass">
        <div class="filters-scroll">
          {categories.map(cat => (
            <button class="filter-chip" data-category={cat}>{cat}</button>
          ))}
        </div>
        <div class="search-minimal">
          <input type="text" id="news-search" placeholder="Buscar en esta página..." />
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        </div>
      </section>
    </div>

    <!-- Gallery Grid -->
    <section class="gallery-container">
      <div class="news-gallery" id="news-grid">
        {newsItems.map((item) => (
          <div class="gallery-item" data-category={item.category} data-title={item.title.toLowerCase()}>
            <NewsCard 
              title={item.title}
              description={item.description}
              slug={item.slug}
              image={item.image}
              date={item.date}
              category={item.category}
            />
          </div>
        ))}
      </div>

      <!-- Pager -->
      <nav class="pagination-nav">
        {page.url.prev ? (
          <a href={page.url.prev.endsWith('/1') ? '/noticias/' : page.url.prev} class="page-link">&larr; Anterior</a>
        ) : (
          <span class="page-link disabled">&larr; Anterior</span>
        )}
        
        <div class="page-info">
          Página <span>{page.currentPage}</span> de {page.lastPage}
        </div>

        {page.url.next ? <a href={page.url.next} class="page-link">Siguiente &rarr;</a> : <span class="page-link disabled">Siguiente &rarr;</span>}
      </nav>
    </section>
  </main>
</BaseLayout>

<script>
  // El mismo script de filtrado que teníamos, pero ahora actúa sobre las noticias de la página actual
  const searchInput = document.getElementById('news-search');
  const filterBtns = document.querySelectorAll('.filter-chip');
  const newsItems = document.querySelectorAll('.gallery-item');
  const newsGrid = document.getElementById('news-grid');

  let currentCategory = "Todas";

  function filterNews() {
    const searchTerm = (searchInput as HTMLInputElement).value.toLowerCase();
    newsItems.forEach(item => {
      const category = item.getAttribute('data-category');
      const title = item.getAttribute('data-title');
      const matchesCategory = currentCategory === "Todas" || category === currentCategory;
      const matchesSearch = title.includes(searchTerm);
      (item as HTMLElement).style.display = (matchesCategory && matchesSearch) ? "block" : "none";
    });
  }

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentCategory = btn.getAttribute('data-category');
      filterNews();
    });
  });

  searchInput?.addEventListener('input', filterNews);
  if (filterBtns[0]) filterBtns[0].classList.add('active');
</script>

<style>
  :root {
    --toolbar-bg: rgba(255, 255, 255, 0.95);
    --toolbar-border: rgba(0, 0, 0, 0.1);
    --toolbar-text: #4a5568;
  }

  :global(.dark-mode) {
    --toolbar-bg: rgba(20, 16, 33, 0.95);
    --toolbar-border: rgba(187, 159, 255, 0.2);
    --toolbar-text: #a0aec0;
  }

  .hero-cinematic {
    position: relative;
    width: 100%;
    height: 60vh;
    min-height: 450px;
    display: flex;
    align-items: flex-end;
    padding-bottom: 60px;
    background: #000;
    margin-top: 30px;
  }

  .hero-bg { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; }
  .hero-bg img { width: 100%; height: 100%; object-fit: cover; filter: brightness(0.45); }
  .hero-overlay { position: absolute; bottom: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(0deg, rgba(0,0,0,0.95) 0%, rgba(0,0,0,0.4) 50%, rgba(0,0,0,0) 100%); }
  .hero-container { position: relative; z-index: 2; width: 100%; max-width: 1200px; }
  .hero-content h1 { font-size: clamp(2rem, 5vw, 3.5rem); color: #fff; line-height: 1.1; margin-bottom: 20px; text-shadow: 0 4px 10px rgba(0,0,0,0.5); border: none !important; }
  .hero-content p { font-size: 1.1rem; color: rgba(255,255,255,0.9); line-height: 1.5; margin-bottom: 30px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .hero-meta { display: flex; align-items: center; gap: 15px; margin-bottom: 20px; color: rgba(255,255,255,0.7); font-size: 0.9rem; }
  .category-chip { background: #bb9fff; color: #000; padding: 2px 12px; font-weight: bold; font-size: 0.75rem; text-transform: uppercase; }
  .cta-banner { display: inline-flex; align-items: center; gap: 12px; color: #bb9fff; text-decoration: none; font-weight: 800; letter-spacing: 2px; font-size: 0.9rem; transition: gap 0.3s ease; }
  .cta-banner:hover { gap: 20px; }

  .toolbar-sticky { position: sticky; top: 120px; z-index: 100; margin-top: -30px; }
  .news-toolbar-glass { background: var(--toolbar-bg); backdrop-filter: blur(15px); -webkit-backdrop-filter: blur(15px); border: 1px solid var(--toolbar-border); padding: 10px 25px; display: flex; justify-content: space-between; align-items: center; gap: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); }
  .filters-scroll { display: flex; gap: 10px; overflow-x: auto; padding: 5px 0; scrollbar-width: none; }
  .filters-scroll::-webkit-scrollbar { display: none; }
  .filter-chip { background: transparent; border: none; padding: 8px 15px; font-weight: 600; font-size: 0.85rem; color: var(--toolbar-text); cursor: pointer; white-space: nowrap; transition: all 0.2s; border-bottom: 2px solid transparent; }
  .filter-chip.active { color: var(--news-accent, #6b46c1); border-bottom-color: var(--news-accent, #6b46c1); }
  :global(.dark-mode) .filter-chip.active { color: #bb9fff; border-bottom-color: #bb9fff; }

  .search-minimal { display: flex; align-items: center; gap: 10px; border-left: 1px solid var(--toolbar-border); padding-left: 20px; max-width: 250px; width: 100%; color: var(--toolbar-text); }
  .search-minimal input { background: transparent; border: none; outline: none; width: 100%; font-size: 0.9rem; color: inherit; }
  .search-minimal input::placeholder { color: var(--toolbar-text); opacity: 0.5; }

  .main-news-section { padding-top: 60px !important; }
  .gallery-container { padding-top: 30px; }
  .news-gallery { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 40px; scroll-margin-top: 200px; }

  /* --- PAGINATION --- */
  .pagination-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 60px;
    padding: 30px 0;
    border-top: 1px solid var(--toolbar-border);
  }

  .page-link {
    padding: 10px 20px;
    background: var(--toolbar-bg);
    border: 1px solid var(--toolbar-border);
    color: var(--toolbar-text);
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
  }

  .page-link:hover:not(.disabled) {
    border-color: #bb9fff;
    color: #bb9fff;
    background: rgba(187, 159, 255, 0.05);
  }

  .page-link.disabled {
    opacity: 0.3;
    pointer-events: none;
    cursor: default;
  }

  .page-info {
    font-size: 0.9rem;
    color: var(--toolbar-text);
    font-weight: 500;
  }

  .page-info span {
    font-weight: 800;
    color: #bb9fff;
  }

  @media (max-width: 1024px) { .toolbar-sticky { top: 120px; } }
  @media (max-width: 768px) {
    .news-toolbar-glass { flex-direction: column; align-items: stretch; padding: 15px; }
    .search-minimal { border: none; border-top: 1px solid var(--toolbar-border); padding: 10px 0 0 0; max-width: none; }
    .hero-cinematic { height: 45vh; }
    .hero-content h1 { font-size: 1.8rem; }
  }
</style>
