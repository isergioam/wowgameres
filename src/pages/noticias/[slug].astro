---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

export async function getStaticPaths() {
  const newsEntry = await getEntry('news', 'latest');
  const newsItems = newsEntry ? newsEntry.data : [];
  
  return newsItems.map((item) => ({
    params: { slug: item.slug },
    props: { news: item },
  }));
}

const { news } = Astro.props;

const formattedDate = new Date(news.date).toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<BaseLayout 
  title={`${news.title} | WOWGamerES`} 
  description={news.description}
  image={news.image}
>
  <!-- Hero Cinematic Details -->
  <header class="news-hero-detail">
    <div class="hero-bg">
      <img src={news.image} alt={news.title} />
      <div class="hero-overlay"></div>
    </div>
    <div class="hero-container content">
      <div class="hero-content">
        <nav class="news-breadcrumb">
          <a href="/">Inicio</a> 
          <span class="sep">/</span> 
          <a href="/noticias">Noticias</a>
          <span class="sep">/</span> 
          <span class="current">{news.category}</span>
        </nav>
        
        <div class="hero-meta">
          <span class="category-chip">{news.category}</span>
          <time datetime={news.date}>{formattedDate}</time>
        </div>
        <h1>{news.title}</h1>
      </div>
    </div>
  </header>

  <article class="news-article">
    <div class="news-body">

      {/* Toggle — solo aparece si hay resumen Y contenido */}
      {news.summary && news.content && (
        <div class="view-toggle">
          <button id="btn-summary" class="toggle-btn active">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
            Resumen
          </button>
          <button id="btn-full" class="toggle-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            Artículo completo
          </button>
        </div>
      )}

      {/* Vista: Resumen */}
      {news.summary && (
        <div id="view-summary" class="view-panel">
          <div class="ai-summary">

            {/* Cabecera visual del resumen */}
            {news.image && (
              <div class="summary-hero-img">
                <img src={news.image} alt={news.title} />
                <div class="summary-hero-gradient" />
                <div class="summary-hero-title">
                  <h2>{news.title}</h2>
                </div>
              </div>
            )}

            <div class="summary-text">
              {news.summary.split('\n').map((paragraph) => (
                paragraph.trim() && <p>{paragraph}</p>
              ))}
            </div>
          </div>
          {!news.content && <p class="no-content">{news.description}</p>}
        </div>
      )}

      {/* Vista: Artículo completo */}
      {news.content && (
        <div id="view-full" class="view-panel" style={news.summary ? "display:none;" : ""}>
          <div class="content-wrapper" set:html={news.content} />
        </div>
      )}

      {/* Si no hay resumen, mostrar el contenido directamente */}
      {!news.summary && !news.content && (
        <p class="no-content">{news.description}</p>
      )}

    </div>

    <footer class="news-article-footer">
      <div class="source-link">
        <p>Esta noticia fue publicada originalmente por Blizzard Entertainment.</p>
        <a href={news.url} target="_blank" rel="noopener noreferrer">Ver fuente original &rarr;</a>
      </div>
      <div class="back-link">
        <a href="/noticias">&larr; Volver a noticias</a>
      </div>
    </footer>
  </article>

  <!-- Botón Flotante para volver rápido -->
  <a href="/noticias" class="floating-back-btn" aria-label="Volver a noticias">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
    <span>VOLVER</span>
  </a>
</BaseLayout>

<script>
  const btnSummary = document.getElementById('btn-summary');
  const btnFull = document.getElementById('btn-full');
  const viewSummary = document.getElementById('view-summary');
  const viewFull = document.getElementById('view-full');

  if (btnSummary && btnFull && viewSummary && viewFull) {
    btnSummary.addEventListener('click', () => {
      btnSummary.classList.add('active');
      btnFull.classList.remove('active');
      viewSummary.style.display = 'block';
      viewFull.style.display = 'none';
    });

    btnFull.addEventListener('click', () => {
      btnFull.classList.add('active');
      btnSummary.classList.remove('active');
      viewFull.style.display = 'block';
      viewSummary.style.display = 'none';
    });
  }
</script>

<style is:global>
  :root {
    --news-text: #2d3748;
    --news-h1: #1a202c;
    --news-bg: #ffffff;
    --news-border: #e2e8f0;
    --news-summary-bg: #f7f4ff;
    --news-summary-border: #dcd3ff;
    --news-accent: #5a32a3;
    --news-meta: #718096;
  }

  .dark-mode {
    --news-text: rgba(255, 255, 255, 0.9);
    --news-h1: #ffffff;
    --news-bg: rgba(255, 255, 255, 0.02);
    --news-border: rgba(255, 255, 255, 0.05);
    --news-summary-bg: rgba(187, 159, 255, 0.08);
    --news-summary-border: rgba(187, 159, 255, 0.3);
    --news-accent: #bb9fff;
    --news-meta: rgba(255, 255, 255, 0.6);
  }

  .content-wrapper { color: var(--news-text); line-height: 1.8; font-size: 1.15rem; }
  .content-wrapper h2 { color: var(--news-accent); margin-top: 40px; margin-bottom: 20px; font-size: 1.8rem; }
  .content-wrapper h3 { color: var(--news-h1); margin-top: 30px; margin-bottom: 15px; font-size: 1.4rem; }
  .content-wrapper a { color: var(--news-accent); text-decoration: underline; }
  .content-wrapper blockquote { border-left: 4px solid var(--news-accent); padding: 10px 20px; background: var(--news-summary-bg); margin: 20px 0; font-style: italic; }
  .content-wrapper hr { border: 0; border-top: 1px solid var(--news-border); margin: 40px 0; }
  
  .content-wrapper img {
    max-width: 100%;
    height: auto;
    border-radius: 0;
    margin: 30px auto;
    display: block;
    border: 1px solid var(--news-border);
  }
</style>

<style>
  /* --- HERO DETAIL --- */
  .news-hero-detail {
    position: relative;
    width: 100%;
    height: 60vh;
    min-height: 450px;
    display: flex;
    align-items: flex-end;
    padding-bottom: 80px;
    background: #000;
    margin-top: 30px; /* Margen de seguridad ajustado */
  }

  .hero-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.45);
  }

  .hero-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(0deg, rgba(0,0,0,0.95) 0%, rgba(0,0,0,0.4) 50%, rgba(0,0,0,0) 100%);
  }

  .hero-container {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 1000px;
    margin: 0 auto;
  }

  .hero-content {
    padding: 0 20px;
  }

  /* --- BREADCRUMBS --- */
  .news-breadcrumb {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 25px;
    font-size: 0.85rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.6);
  }

  .news-breadcrumb a {
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    transition: color 0.2s;
  }

  .news-breadcrumb a:hover {
    color: #bb9fff;
  }

  .news-breadcrumb .sep {
    opacity: 0.4;
  }

  .news-breadcrumb .current {
    color: #bb9fff;
    font-weight: 600;
  }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: 15px;
    margin-bottom: 15px;
    color: rgba(255,255,255,0.7);
    font-size: 0.9rem;
  }

  .category-chip {
    background: var(--news-accent);
    color: #fff;
    padding: 2px 12px;
    font-weight: bold;
    font-size: 0.75rem;
    text-transform: uppercase;
  }

  .dark-mode .category-chip { color: #000; }

  h1 {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    color: #fff;
    line-height: 1.2;
    max-width: 900px;
    text-shadow: 0 4px 10px rgba(0,0,0,0.5);
    margin: 0;
    border: none !important;
  }

  /* --- ARTICLE BODY --- */
  .news-article {
    max-width: 900px;
    margin: 0 auto;
    padding: 20px;
    position: relative;
    z-index: 10;
    margin-top: -40px;
  }

  .news-body {
    background: var(--news-bg);
    padding: 40px;
    border: 1px solid var(--news-border);
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  }

  /* --- TOGGLE RESUMEN / COMPLETO --- */
  .view-toggle {
    display: flex;
    gap: 0;
    margin-bottom: 35px;
    border: 1px solid var(--news-summary-border);
    width: fit-content;
  }

  .toggle-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 22px;
    background: transparent;
    border: none;
    color: var(--news-text);
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    opacity: 0.5;
  }

  .toggle-btn:first-child {
    border-right: 1px solid var(--news-summary-border);
  }

  .toggle-btn.active {
    background: var(--news-summary-bg);
    color: var(--news-accent);
    opacity: 1;
  }

  .toggle-btn svg {
    stroke: currentColor;
  }

  .view-panel {
    animation: fadeIn 0.3s ease;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(5px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  :global(.dark-mode) .news-body {
    box-shadow: 0 10px 40px rgba(0,0,0,0.4);
  }

  .ai-summary {
    background: var(--news-summary-bg);
    border: 1px solid var(--news-summary-border);
    padding: 30px;
    margin-bottom: 50px;
  }

  .summary-hero-img {
    position: relative;
    width: calc(100% + 60px);
    margin: -30px -30px 30px -30px;
    height: 260px;
    overflow: hidden;
  }

  .summary-hero-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.5);
  }

  .summary-hero-gradient {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 70%;
    background: linear-gradient(to top, var(--news-summary-bg) 0%, transparent 100%);
  }

  .summary-hero-title {
    position: absolute;
    bottom: 20px;
    left: 25px;
    right: 25px;
  }

  .summary-hero-title h2 {
    font-size: clamp(1.1rem, 2.5vw, 1.6rem);
    font-weight: 800;
    color: #fff;
    line-height: 1.2;
    text-shadow: 0 2px 8px rgba(0,0,0,0.8);
    margin: 0;
    border: none !important;
  }

  .summary-text p {
    font-size: 1.15rem;
    line-height: 1.7;
    color: var(--news-text);
  }

  .news-article-footer {
    margin-top: 50px;
    padding: 30px 0;
    border-top: 1px solid var(--news-border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
  }

  .source-link a { color: var(--news-accent); font-weight: 600; text-decoration: none; }
  .back-link a { color: var(--news-text); text-decoration: none; opacity: 0.8; }

  /* --- FLOATING BACK BUTTON --- */
  .floating-back-btn {
    position: fixed;
    top: 50%;
    left: 40px;
    transform: translateY(-50%);
    background: var(--news-bg);
    border: 1px solid var(--news-accent);
    color: var(--news-accent);
    padding: 12px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    z-index: 100;
    text-decoration: none;
    font-weight: 800;
    font-size: 0.7rem;
    letter-spacing: 1px;
    transition: all 0.3s ease;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  }

  :global(.dark-mode) .floating-back-btn {
    box-shadow: 0 10px 40px rgba(0,0,0,0.4);
  }

  .floating-back-btn:hover {
    background: var(--news-accent);
    color: #fff;
    transform: translateY(-50%) translateX(-5px);
  }

  :global(.dark-mode) .floating-back-btn:hover {
    color: #000;
  }

  @media (max-width: 1400px) {
    .floating-back-btn {
      left: 10px;
      padding: 10px 5px;
    }
    .floating-back-btn span { display: none; }
  }

  @media (max-width: 768px) {
    .news-body { padding: 25px; }
    .news-article { margin-top: 0; padding: 15px; }
    .news-hero-detail { height: 45vh; min-height: 350px; padding-bottom: 40px; }
    
    .floating-back-btn {
      top: auto;
      bottom: 20px;
      left: 20px;
      transform: none;
      flex-direction: row;
      padding: 10px 20px;
      border-radius: 50px; /* En móvil lo hacemos más amigable al pulgar */
      box-shadow: 0 5px 20px rgba(0,0,0,0.3);
    }
    
    .floating-back-btn span { display: block; }
    .floating-back-btn:hover { transform: scale(1.05); }
  }
</style>
