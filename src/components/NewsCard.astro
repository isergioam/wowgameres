---
interface Props {
  title: string;
  description: string;
  slug: string;
  image: string;
  date: string;
  category: string;
}

const { title, description, slug, image, date, category } = Astro.props;
const url = `/noticias/${slug}`;

// Formatear fecha
const formattedDate = new Date(date).toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<article class="news-card">
  <a href={url} class="news-card-link">
    <div class="news-image-container">
      <img src={image} alt={title} loading="lazy" class="news-image" />
      <span class="news-category">{category}</span>
    </div>
    <div class="news-content">
      <time datetime={date} class="news-date">{formattedDate}</time>
      <h3 class="news-title">{title}</h3>
      <p class="news-description">{description}</p>
      <div class="news-footer">
        <span class="read-more">Leer artículo &rarr;</span>
      </div>
    </div>
  </a>
</article>

<style>
  .news-card {
    --card-bg: #f8f5ff;
    --card-border: rgba(187, 159, 255, 0.2);
    --card-title: #1a1a1a;
    --card-desc: #4a4a4a;
    --card-accent: #6b46c1;
    
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 0;
    overflow: hidden;
    transition: all 0.3s ease;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  :global(.dark-mode) .news-card {
    --card-bg: rgba(255, 255, 255, 0.03);
    --card-border: rgba(255, 255, 255, 0.1);
    --card-title: #ffffff;
    --card-desc: rgba(255, 255, 255, 0.7);
    --card-accent: #bb9fff;
  }

  .news-card:hover {
    transform: translateY(-5px);
    border-color: var(--card-accent);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
  }

  :global(.dark-mode) .news-card:hover {
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
  }

  .news-card-link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .news-image-container {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .news-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .news-card:hover .news-image {
    transform: scale(1.05);
  }

  .news-category {
    position: absolute;
    top: 10px;
    right: 10px;
    background: var(--card-accent);
    color: #fff;
    font-size: 0.75rem;
    font-weight: bold;
    padding: 4px 10px;
    border-radius: 0;
    text-transform: uppercase;
  }

  :global(.dark-mode) .news-category {
    color: #000;
  }

  .news-content {
    padding: 20px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .news-date {
    font-size: 0.85rem;
    color: var(--card-accent);
    opacity: 0.8;
    margin-bottom: 8px;
    display: block;
  }

  .news-title {
    font-size: 1.25rem;
    margin: 0 0 12px 0;
    line-height: 1.4;
    color: var(--card-title);
    font-weight: 600;
  }

  .news-description {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--card-desc);
    margin: 0 0 20px 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .news-footer {
    margin-top: auto;
  }

  .read-more {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--card-accent);
  }

  @media (max-width: 768px) {
    .news-title {
      font-size: 1.1rem;
    }
  }
</style>
