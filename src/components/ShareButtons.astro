---
// src/components/ShareButtons.astro
---

<div class="share-container reveal">
  <div class="share-inner">
    <h3 class="share-title">¿Te ha servido la guía? ¡Compártela!</h3>
    <div class="share-buttons">
      <a
        href="#"
        id="share-whatsapp"
        class="share-btn whatsapp"
        target="_blank"
        rel="noopener noreferrer"
        title="Compartir por WhatsApp"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path
            d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 1 1-7.6-11.7 8.38 8.38 0 0 1 3.8.9L21 3z"
          ></path></svg
        >
        <span>WhatsApp</span>
      </a>

      <a
        href="#"
        id="share-x"
        class="share-btn x"
        target="_blank"
        rel="noopener noreferrer"
        title="Compartir en X"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"/></svg>
      </a>

      <button
        id="share-discord"
        class="share-btn discord"
        title="Copiar enlace para Discord"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 127.14 96.36" fill="currentColor"><path d="M107.7,8.07A105.15,105.15,0,0,0,81.47,0a72.06,72.06,0,0,0-3.36,6.83A97.68,97.68,0,0,0,49,6.83,72.37,72.37,0,0,0,45.64,0,105.89,105.89,0,0,0,19.39,8.09C2.71,32.65-1.82,56.6.39,80.21a105.73,105.73,0,0,0,32.17,16.15,77.7,77.7,0,0,0,6.89-11.11,68.42,68.42,0,0,1-10.85-5.18c.91-.66,1.8-1.34,2.66-2a75.57,75.57,0,0,0,64.32,0c.87.71,1.76,1.39,2.66,2a68.68,68.68,0,0,1-10.87,5.19,77,77,0,0,0,6.89,11.1,105.25,105.25,0,0,0,32.19-16.14c2.64-27.38-4.52-51.06-19.1-72.13ZM42.45,65.69C36.18,65.69,31,60,31,53s5.07-12.59,11.44-12.59S54,46.13,53.88,53.11,48.72,65.69,42.45,65.69Zm42.24,0C78.41,65.69,73.25,60,73.25,53s5.07-12.59,11.44-12.59S96.26,46,96.12,53.11,91,65.69,84.69,65.69Z"/></svg>
        <span class="discord-text">Discord</span>
      </button>

      <a
        href="#"
        id="share-telegram"
        class="share-btn telegram"
        target="_blank"
        rel="noopener noreferrer"
        title="Compartir en Telegram"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><line x1="22" y1="2" x2="11" y2="13"></line><polygon
            points="22 2 15 22 11 13 2 9 22 2"></polygon></svg
        >
        <span>Telegram</span>
      </a>


    </div>
  </div>
</div>

<style>
  .share-container {
    margin: 60px auto;
    max-width: 800px;
    padding: 2px;
    background: linear-gradient(135deg, var(--primary-purple), #8a2be2);
    position: relative;
  }

  /* Efecto de borde premium */
  .share-inner {
    background: var(--bg-color);
    padding: 40px 20px;
    text-align: center;
  }

  .dark-mode .share-inner {
    background: #0a0a0a;
  }

  .share-title {
    font-size: 1.4rem;
    color: var(--primary-purple);
    margin-bottom: 25px;
    font-weight: 800;
    border: none !important;
    padding: 0 !important;
  }

  .dark-mode .share-title {
    color: #bb9fff;
  }

  .share-buttons {
    display: flex;
    justify-content: center;
    gap: 15px;
    flex-wrap: wrap;
  }

  .share-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 24px;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.95rem;
    transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);
    cursor: pointer;
    border: 1px solid var(--primary-purple);
    background: transparent;
    color: var(--primary-purple);
  }

  .dark-mode .share-btn {
    border-color: #bb9fff;
    color: #bb9fff;
  }

  .share-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 20px var(--primary-glow);
  }

  /* Colores específicos en hover */
  .whatsapp:hover {
    background: #25d366;
    border-color: #25d366;
    color: white;
  }
  .x:hover {
    background: #000000;
    border-color: #000000;
    color: white;
  }
  .discord:hover {
    background: #5865f2;
    border-color: #5865f2;
    color: white;
  }
  .telegram:hover {
    background: #0088cc;
    border-color: #0088cc;
    color: white;
  }
  .copy:hover {
    background: var(--primary-purple);
    border-color: var(--primary-purple);
    color: white;
  }

  .dark-mode .x:hover {
    background: #ffffff;
    color: #000;
    border-color: #ffffff;
  }
  .dark-mode .discord:hover {
    background: #5865f2;
    color: #fff;
    border-color: #5865f2;
  }

  .share-btn svg {
    transition: transform 0.3s ease;
  }

  .share-btn:hover svg {
    transform: scale(1.1);
  }

  @media (max-width: 600px) {
    .share-btn span {
      display: none;
    }
    .share-btn {
      padding: 15px;
    }
    .share-title {
      font-size: 1.2rem;
    }
  }
</style>

<script>
  function initShare() {
    const url = window.location.href;
    const title = document.title;
    const text = `Esta guía de WOWGamerES está genial: ${title}`;

    const whatsapp = document.getElementById("share-whatsapp");
    const xBtn = document.getElementById("share-x");
    const telegram = document.getElementById("share-telegram");
    const discordBtn = document.getElementById("share-discord");

    if (whatsapp)
      whatsapp.setAttribute(
        "href",
        `https://api.whatsapp.com/send?text=${encodeURIComponent(text + " " + url)}`,
      );
    if (xBtn)
      xBtn.setAttribute(
        "href",
        `https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}&url=${encodeURIComponent(url)}`,
      );
    if (telegram)
      telegram.setAttribute(
        "href",
        `https://t.me/share/url?url=${encodeURIComponent(url)}&text=${encodeURIComponent(text)}`,
      );

    if (discordBtn) {
      discordBtn.addEventListener("click", () => {
        navigator.clipboard.writeText(url).then(() => {
          const textSpan = discordBtn.querySelector(".discord-text");
          if (textSpan) {
            const originalText = textSpan.textContent;
            textSpan.textContent = "¡Copiado!";
            setTimeout(() => {
              textSpan.textContent = originalText;
            }, 2000);
          }
        });
      });
    }


  }

  // Ejecutar al cargar
  initShare();
  // Soporte para futuras transiciones de Astro
  document.addEventListener("astro:after-swap", initShare);
</script>
